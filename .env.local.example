# =============================================================================
# Crew environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.
# =============================================================================

# --- Convex -----------------------------------------------------------------
# Created automatically when you run `npx convex dev` for the first time.
# Production MUST set a real URL (no placeholder). See app/providers.tsx.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# --- Clerk ------------------------------------------------------------------
# Use a dedicated Clerk application for Crew in production.
# Sharing SiteAssist/Echo keys is OK for local smoke tests only (L10).
# https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# The "Issuer" (Frontend API) URL from your Clerk JWT template named "convex".
# Clerk dashboard -> JWT Templates -> New template -> Convex.
# Looks like: https://your-app.clerk.accounts.dev
# Also set on Convex: npx convex env set CLERK_JWT_ISSUER_DOMAIN <issuer>
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev

# Where Clerk should send users for auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- OpenAI (Convex deployment only) ----------------------------------------
# Used server-side inside Convex actions. Set on the deployment:
#   npx convex env set OPENAI_API_KEY sk-...
#   npx convex env set OPENAI_MODEL gpt-4o-mini
# OPENAI_API_KEY=<your-openai-api-key>
# OPENAI_MODEL=gpt-4o-mini
